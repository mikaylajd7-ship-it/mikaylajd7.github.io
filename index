<!DOCTYPE html>
<html lang="en">
<head>
  <!--
    Name: Mikayla Dickerson
    Date: 06-22-2026

    Purpose: This webpage serves as a personal portfolio homepage
    with About, Projects, and Contact sections. It also includes
    JavaScript that personalizes the user experience.
  -->

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mikayla Dickerson Portfolio</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      line-height: 1.6;
    }

    header {
      background: #2c3e50;
      color: white;
      padding: 20px;
      text-align: center;
    }

    nav {
      background: #34495e;
      display: flex;
      justify-content: center;
      gap: 20px;
      padding: 10px;
    }

    nav a {
      color: white;
      text-decoration: none;
    }

    section {
      padding: 20px;
    }

    .project img {
      width: 200px;
      height: auto;
      margin: 10px;
      border: 1px solid #ccc;
    }

    form {
      display: flex;
      flex-direction: column;
      max-width: 400px;
    }

    input, textarea {
      margin-bottom: 10px;
      padding: 8px;
    }

    button {
      padding: 10px;
      background: #2c3e50;
      color: white;
      border: none;
      cursor: pointer;
    }
  </style>
</head>

<body>

  <!-- Personalized welcome message -->
  <header>
    <h1 id="welcomeMessage">Welcome to My Portfolio</h1>
  </header>

  <!-- Navigation Menu -->
  <nav>
    <a href="#about">About</a>
    <a href="#projects">Projects</a>
    <a href="#contact">Contact</a>
  </nav>

  <!-- About Section -->
  <section id="about">
    <h2>About</h2>
    <p>
      Hello! My name is Mikayla Dickerson. I am currently building my skills in web development,
      programming, and IT systems. I enjoy learning how technology works and applying it to real-world
      projects. This portfolio showcases some of my work and progress.
    </p>
  </section>

  <!-- Projects Section -->
  <section id="projects">
    <h2>Projects</h2>

    <div class="project">
      <p>Project 1</p>
      <a href="https://github.com/yourusername/project1">
        <img src="https://via.placeholder.com/200" alt="Project 1">
      </a>
    </div>

    <div class="project">
      <p>Project 2</p>
      <a href="https://github.com/yourusername/project2">
        <img src="https://via.placeholder.com/200" alt="Project 2">
      </a>
    </div>

    <div class="project">
      <p>Project 3</p>
      <a href="https://github.com/yourusername/project3">
        <img src="https://via.placeholder.com/200" alt="Project 3">
      </a>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact">
    <h2>Contact</h2>

    <form>
      <input type="text" name="name" placeholder="Your Name" required>
      <input type="email" name="email" placeholder="Your Email" required>
      <input type="text" name="subject" placeholder="Subject" required>
      <textarea name="message" rows="5" placeholder="Message" required></textarea>

      <button type="submit">Submit</button>
    </form>
  </section>

  <!-- JavaScript for personalized interaction -->
  <script>
    // Prompt the user for their name
    let userName = prompt("Please enter your name:");

    // If user enters nothing, set a default name
    if (!userName) {
      userName = "Guest";
    }

    // Update the welcome message dynamically
    document.getElementById("welcomeMessage").textContent =
      "Welcome, " + userName + ", to My Portfolio!";
  </script>

</body>
</html>
