<!DOCTYPE html>
<html lang="en">
<head>
  <!--
    Name: Mikayla Dickerson
    Student ID: mikdic9704
    Date: 06-22-2026

    Purpose: Personal portfolio homepage with About, Projects,
    and Contact sections plus JavaScript personalization.
  -->

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mikayla Dickerson Portfolio</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      line-height: 1.6;
      background-color: #f4f4f4;
    }

    header {
      background: #2c3e50;
      color: white;
      padding: 20px;
      text-align: center;
    }

    nav {
      background: #34495e;
      display: flex;
      justify-content: center;
      gap: 20px;
      padding: 10px;
    }

    nav a {
      color: white;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover {
      text-decoration: underline;
    }

    section {
      background: white;
      margin: 15px;
      padding: 20px;
      border-radius: 8px;
    }

    .project img {
      width: 200px;
      height: auto;
      border: 1px solid #ccc;
      margin-top: 5px;
    }

    .project {
      margin-bottom: 20px;
    }

    form {
      display: flex;
      flex-direction: column;
      max-width: 400px;
    }

    label {
      margin-top: 10px;
      font-weight: bold;
    }

    input, textarea {
      margin-top: 5px;
      padding: 8px;
    }

    button {
      margin-top: 15px;
      padding: 10px;
      background: #2c3e50;
      color: white;
      border: none;
      cursor: pointer;
    }

    button:hover {
      background: #1a242f;
    }
  </style>
</head>

<body>

  <!-- Personalized welcome message -->
  <header>
    <h1 id="welcomeMessage">Welcome to My Portfolio</h1>
  </header>

  <!-- Navigation -->
  <nav>
    <a href="#about">About</a>
    <a href="#projects">Projects</a>
    <a href="#contact">Contact</a>
  </nav>

  <!-- About Section -->
  <section id="about">
    <h2>About</h2>
    <p>
      Hello! My name is Mikayla Dickerson. I am learning web development and IT skills,
      including HTML, CSS, JavaScript, and networking concepts. This portfolio showcases
      my progress and projects.
    </p>
  </section>

  <!-- Projects Section -->
  <section id="projects">
    <h2>Projects</h2>

    <div class="project">
      <h3>Project 1</h3>
      <a href="https://github.com/yourusername/project1" target="_blank">
        <img src="https://via.placeholder.com/200" alt="Project 1 Screenshot">
      </a>
    </div>

    <div class="project">
      <h3>Project 2</h3>
      <a href="https://github.com/yourusername/project2" target="_blank">
        <img src="https://via.placeholder.com/200" alt="Project 2 Screenshot">
      </a>
    </div>

    <div class="project">
      <h3>Project 3</h3>
      <a href="https://github.com/yourusername/project3" target="_blank">
        <img src="https://via.placeholder.com/200" alt="Project 3 Screenshot">
      </a>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact">
    <h2>Contact</h2>

    <form>
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required>

      <label for="email">Email</label>
      <input type="email" id="email" name="email" required>

      <label for="subject">Subject</label>
      <input type="text" id="subject" name="subject" required>

      <label for="message">Message</label>
      <textarea id="message" name="message" rows="5" required></textarea>

      <button type="submit">Submit</button>
    </form>
  </section>

  <!-- JavaScript personalization -->
  <script>
    let userName = prompt("Please enter your name:");

    // Handle cancel or empty input
    if (!userName || userName.trim() === "") {
      userName = "Guest";
    }

    document.getElementById("welcomeMessage").textContent =
      "Welcome, " + userName + ", to My Portfolio!";
  </script>

</body>
</html>
